# Optional explicit project root
SIGNALS_PROJECT_ROOT=/Users/raramuri/Projects/zopdev/signals

# Postgres connection (SIGNALS_PG_DSN overrides SIGNALS_PG_* when set)
SIGNALS_PG_DSN=
SIGNALS_PG_HOST=127.0.0.1
SIGNALS_PG_PORT=55432
SIGNALS_PG_USER=signals
SIGNALS_PG_PASSWORD=signals_dev_password
SIGNALS_PG_DB=signals
SIGNALS_TEST_PG_DSN=postgresql://signals:signals_dev_password@127.0.0.1:55432/signals_test

# Timezone used for daily runs
SIGNALS_RUN_TIMEZONE=America/Los_Angeles

# Google Sheets integration
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SERVICE_ACCOUNT_FILE=

# Optional collection controls
SIGNALS_ENABLE_LIVE_CRAWL=0
SIGNALS_HTTP_TIMEOUT_SECONDS=10
SIGNALS_HTTP_USER_AGENT=zopdev-signals/0.1
SIGNALS_HTTP_PROXY_URL=
SIGNALS_RESPECT_ROBOTS_TXT=1
SIGNALS_MIN_DOMAIN_REQUEST_INTERVAL_MS=2000
SIGNALS_LIVE_MAX_ACCOUNTS=1000
SIGNALS_LIVE_WORKERS_PER_SOURCE=auto
SIGNALS_AUTO_DISCOVER_JOB_HANDLES=0
SIGNALS_LIVE_MAX_JOBS_PER_SOURCE=60

# Discovery webhook and pipeline controls
SIGNALS_DISCOVERY_WEBHOOK_TOKEN=
SIGNALS_DISCOVERY_EVENT_BATCH_SIZE=500
SIGNALS_DISCOVERY_LOOKBACK_DAYS=120
SIGNALS_STAGE_TIMEOUT_SECONDS=1800
SIGNALS_RETRY_ATTEMPT_LIMIT=3

# Alerts and notifications
SIGNALS_GCHAT_WEBHOOK_URL=
SIGNALS_ALERT_EMAIL_TO=
SIGNALS_ALERT_EMAIL_FROM=
SIGNALS_ALERT_SMTP_HOST=
SIGNALS_ALERT_SMTP_PORT=587
SIGNALS_ALERT_SMTP_USER=
SIGNALS_ALERT_SMTP_PASSWORD=
SIGNALS_ALERT_RETRY_DEPTH_THRESHOLD=2
SIGNALS_ALERT_MIN_HIGH_PRECISION=0.65
SIGNALS_ALERT_MIN_MEDIUM_PRECISION=0.55
SIGNALS_OPS_METRICS_LOOKBACK_DAYS=14

# Story-deep hunt controls
SIGNALS_HUNT_PROFILE=light
SIGNALS_HUNT_JS_FALLBACK_CAP=60

# Watchlist refresh parallelism
SIGNALS_WATCHLIST_QUERY_WORKERS=8
SIGNALS_WATCHLIST_COUNTRY_TIMEOUT_SECONDS=120
