# PostgreSQL container
SIGNALS_PG_USER=signals
SIGNALS_PG_PASSWORD=signals_dev_password
SIGNALS_PG_DB=signals
SIGNALS_PG_PORT=55432

# Redis container
SIGNALS_REDIS_PORT=56379

# Huginn container
HUGINN_PORT=3000
HUGINN_DOMAIN=localhost:3000
HUGINN_INVITATION_CODE=signals-local
HUGINN_APP_SECRET_TOKEN=replace-with-long-random-token
HUGINN_PG_USER=signals
HUGINN_PG_PASSWORD=signals_dev_password
HUGINN_PG_DB=signals

# Safe networking defaults (not for evasion)
SIGNALS_RESPECT_ROBOTS_TXT=1
SIGNALS_MIN_DOMAIN_REQUEST_INTERVAL_MS=2000
# SIGNALS_HTTP_PROXY_URL=http://your-approved-egress-proxy:8080

# Watchlist fetch tuning
SIGNALS_WATCHLIST_QUERY_WORKERS=8
SIGNALS_WATCHLIST_COUNTRY_TIMEOUT_SECONDS=120
